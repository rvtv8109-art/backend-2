                    newSquadNumber = latestSquadNumber + 1;
                  } else {
                    newSquadNumber = 1 + launchApprovedSnapshot.data().count;
                  }
                } else {
                  newSquadNumber = 1;
                }
              }
            } else {
              const snapshot = await getCountFromServer(collection(db, collectionName));
              newSquadNumber = 1 + snapshot.data().count;
            }

