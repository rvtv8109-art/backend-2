const PartnerDashboard = ({ 
  isOpen, 
  onClose,
  rewardAmount = 0,
  discountAmount = 10
}: { 
  isOpen: boolean; 
  onClose: () => void;
  rewardAmount?: number;
  discountAmount?: number;
}) => {
  const [partner, setPartner] = useState<any>(null);
  const [referrals, setReferrals] = useState<any[]>([]);
  const [payouts, setPayouts] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [user, setUser] = useState<any>(null);
  const [loginLoading, setLoginLoading] = useState(false);
  const [activeTab, setActiveTab] = useState<'dashboard' | 'referrals' | 'payouts' | 'settings'>('dashboard');

  useEffect(() => {
    const unsubscribe = onAuthStateChanged(auth, (u) => {
      setUser(u);
      if (u) {
        fetchPartnerData(u.uid);
      } else {
        setPartner(null);
        setLoading(false);
      }
    });
    return () => unsubscribe();
  }, []);

  const fetchPartnerData = async (uid: string) => {
    setLoading(true);
    try {
      const pDoc = await getDoc(doc(db, 'partners', uid));

      if (pDoc.exists()) {
        setPartner({ id: pDoc.id, ...pDoc.data() });
        fetchReferrals(uid);
        fetchPayouts(uid);
      } else {
        setPartner(null);
      }
    } catch (error) {
      const fsError = handleFirestoreError(error, OperationType.GET, `partners/${uid}`);
      console.error('Error fetching partner data:', fsError);
    } finally {
      setLoading(false);
    }
  };

  const fetchReferrals = async (uid: string) => {
    try {
      const referralsRef = collection(db, 'referrals');
      const q = query(referralsRef, where('partnerUid', '==', uid), orderBy('createdAt', 'desc'));
      const querySnapshot = await getDocs(q);
      const data = querySnapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      setReferrals(data);
    } catch (error) {
      console.error('Error fetching referrals:', error);
    }
  };

  const fetchPayouts = async (uid: string) => {
    try {
      const payoutsRef = collection(db, 'payouts');
      const q = query(payoutsRef, where('partnerUid', '==', uid), orderBy('createdAt', 'desc'));
      const querySnapshot = await getDocs(q);
      const data = querySnapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      setPayouts(data);
    } catch (error) {
      console.error('Error fetching payouts:', error);
    }
  };

  const handleLogin = async () => {
    setLoginLoading(true);
    try {
      const provider = new GoogleAuthProvider();
      await signInWithPopup(auth, provider);
    } catch (error) {
      console.error('Login error:', error);
      alert('Login failed. Please try again.');
    } finally {
      setLoginLoading(false);
    }
  };

  const createPartnerAccount = async () => {
    if (!user) return;
    setLoading(true);
    try {
      // Generate a unique coupon code: first 4 chars of name + random 4 digits
      const namePart = (user.displayName || 'PART').substring(0, 4).toUpperCase();
      const randomPart = Math.floor(1000 + Math.random() * 9000);
      const couponCode = `${namePart}${randomPart}`;

      const partnerData = {
        uid: user.uid,
        email: user.email,
        displayName: user.displayName,
        couponCode,
        totalEarnings: 0,
        balance: 0,
        createdAt: new Date().toISOString()
      };

      await setDoc(doc(db, 'partners', user.uid), partnerData);
      setPartner({ id: user.uid, ...partnerData });
    } catch (error) {
      const fsError = handleFirestoreError(error, OperationType.CREATE, `partners/${user.uid}`);
      console.error('Error creating partner account:', fsError);
      alert('Failed to create partner account. Please ensure you are logged in correctly.');
    } finally {
      setLoading(false);
    }
  };

  const handleWithdraw = async () => {
    const amountToWithdraw = partner.balance;
    if (amountToWithdraw < 500) {
      alert('Minimum withdrawal amount is ₹500.');
      return;
    }
    
    try {
      const payoutData = {
        partnerUid: user.uid,
        partnerEmail: user.email,
        amount: amountToWithdraw,
        status: 'pending',
        createdAt: new Date().toISOString()
      };
      
      // 1. Create payout record
      await addDoc(collection(db, 'payouts'), payoutData);
      
      // 2. Deduct from partner balance
      const partnerRef = doc(db, 'partners', user.uid);
      await updateDoc(partnerRef, {
        balance: 0 // Deducting full balance as requested in payoutData.amount
      });

      alert('Withdrawal request submitted! Our team will contact you soon.');
      fetchPartnerData(user.uid); // Refresh partner data to show updated balance
      fetchPayouts(user.uid);
    } catch (error) {
      console.error('Error submitting withdrawal:', error);
      alert('Failed to submit withdrawal request.');
    }
  };

