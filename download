                            <div className="flex flex-col gap-2">
                              <label className="text-xs uppercase tracking-widest text-white/40 font-bold">Success Message</label>
                              <textarea 
                                value={successMessage}
                                onChange={(e) => setSuccessMessage(e.target.value)}
                                rows={3}
                                className="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:border-cyber-red outline-none text-white transition-all text-sm leading-relaxed"
                                required
                              />
                              <div className="flex gap-2 pt-1 overflow-x-auto custom-scrollbar pb-1">
                                {['PLAYER_TYPE', 'SQUAD_NUMBER', 'SQUAD_NAME'].map(tag => (
                                  <code key={tag} className="text-[9px] text-cyber-red bg-white/5 px-2 py-0.5 rounded border border-white/5 whitespace-nowrap cursor-pointer" onClick={() => navigator.clipboard.writeText('{{' + tag + '}}')}>
                                    {'{{' + tag + '}}'}
                                  </code>
                                ))}
                              </div>
                            </div>
                          </div>
                        </div>

                        <button 
                          type="submit"
                          disabled={isSavingSettings}
                          className="w-full py-4 bg-cyber-red text-cyber-black font-bold uppercase tracking-widest rounded-full hover:shadow-[0_0_20px_rgba(255,0,60,0.5)] transition-all flex items-center justify-center gap-3 disabled:opacity-50 disabled:cursor-not-allowed"
                        >
                          {isSavingSettings ? (
                            <div className="w-5 h-5 border-2 border-cyber-black border-t-transparent rounded-full animate-spin" />
                          ) : (
                            <>
                              <CheckCircle2 className="w-5 h-5" /> Save Settings
                            </>
                          )}
                        </button>
                      </form>
                    </div>
                  </div>
                </div>
              ) : (
                <div className="flex-grow flex items-center justify-center p-8">
                  <p className="text-white/30 italic">Select a tab to continue.</p>
                </div>
              )}
            </div>
          </motion.div>
        </div>
      )}
    </AnimatePresence>
  );
};

