  const [email, setEmail] = useState('');
  const [ticket, setTicket] = useState<any | null>(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');
  const [copied, setCopied] = useState(false);

  useEffect(() => {
    if (initialEmail && isOpen) {
      setEmail(initialEmail);
      fetchTicket(initialEmail);
    }
  }, [initialEmail, isOpen]);

  const fetchTicket = async (searchEmail: string) => {
    setLoading(true);
    setError('');
    
    try {
      const collectionName = tournamentId === 'grand-tournament' ? 'registrations' : `registrations_${tournamentId.replace(/-/g, '_')}`;
      const q = query(
        collection(db, collectionName), 
        where('email', '==', searchEmail.trim().toLowerCase())
      );
      const querySnapshot = await getDocs(q);
      
      if (querySnapshot.empty) {
        // Fallback for legacy or cross-collection check if needed
        if (collectionName !== 'registrations') {
           const qLegacy = query(collection(db, 'registrations'), where('email', '==', searchEmail.trim().toLowerCase()), where('matchId', '==', tournamentId));
           const snapLegacy = await getDocs(qLegacy);
           if (!snapLegacy.empty) {
             setTicket(snapLegacy.docs[0].data());
             return;
           }
        }
        setError('No registration found for this email in this tournament.');
        setTicket(null);
      } else {
        setTicket(querySnapshot.docs[0].data());
      }
    } catch (err) {
      console.error('Error fetching ticket:', err);
      setError('Failed to fetch entry pass. Please try again.');
      setTicket(null);
    } finally {
      setLoading(false);
    }
