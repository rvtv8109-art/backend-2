              ...pendingData.formData,
              email: (pendingData.formData.email || '').trim().toLowerCase(),
              squadNumber: newSquadNumber,
              matchName: pendingData.tournamentTitle,
              matchId: pendingData.tournamentId,
              createdAt: new Date().toISOString(),
              discount: pendingData.discount,
              totalAmount: pendingData.amount,
              partnerUid: pendingData.formData.referrerId || '',
              status: 'confirmed',
              paymentStatus: 'paid',
              cashfree_order_id: orderId
            };

            await addDoc(collection(db, collectionName), finalData);
            
            // Apply referral rewards
            if (pendingData.discount > 0 && pendingData.couponCode) {
              // Re-implement applyReferral logic here or make it a global helper
              // For now we'll rely on the manual check
              const applyReferralManual = async (couponCode: string, newUserId?: string) => {
                const code = couponCode.trim().toUpperCase();
                const partnersRef = collection(db, 'partners');
                let q = query(partnersRef, where('couponCode', '==', code));
                let querySnapshot = await getDocs(q);
                if (querySnapshot.empty) {
                  q = query(partnersRef, where('couponCode', '==', code.toLowerCase()));
                  querySnapshot = await getDocs(q);
                }
                if (!querySnapshot.empty) {
                  const partnerDoc = querySnapshot.docs[0];
                  const partnerData = partnerDoc.data();
                  const referrerId = partnerDoc.id;
                  if (newUserId !== referrerId) {
                    const actualReward = pendingData.tournamentId === 'launch-cup' ? 10 : 50; 
                    await updateDoc(doc(db, "partners", referrerId), {
                      balance: (partnerData.balance || 0) + actualReward,
                      totalEarnings: (partnerData.totalEarnings || 0) + actualReward
                    });
                    await addDoc(collection(db, 'referrals'), {
                      partnerUid: referrerId,
                      newUserId: newUserId || 'ANONYMOUS',
                      playerEmail: pendingData.formData.email,
                      matchId: pendingData.tournamentId,
                      amount: actualReward,
                      status: 'completed',
                      createdAt: new Date().toISOString()
                    });
                  }
                }
              };
              await applyReferralManual(pendingData.couponCode, currentUserId);
