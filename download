  async function applyReferral(couponCode: string | undefined, newUserId: string | undefined, tournamentId: string = 'grand-tournament') {
    if (!couponCode) return 0;
    const code = couponCode.trim().toUpperCase();
    console.log("Applying referral:", code);

    if (!code) return 0;

    // 1. Find the partner (checking both cases)
    const partnersRef = collection(db, 'partners');
    let q = query(partnersRef, where('couponCode', '==', code.toUpperCase()));
    let querySnapshot = await getDocs(q);

    if (querySnapshot.empty) {
      q = query(partnersRef, where('couponCode', '==', code.toLowerCase()));
      querySnapshot = await getDocs(q);
    }

    if (querySnapshot.empty) {
      console.warn("Referral code not found during application");
      return 0;
    }

    const partnerDoc = querySnapshot.docs[0];
    const partnerData = partnerDoc.data();
    const referrerId = partnerData.uid;

    // Prevent self-referral
    if (newUserId && referrerId === newUserId) {
      return 0;
    }

    // 3. Update partner balance
    // If discount is 10, reward is 0 as per user request
    const actualReward = discountAmount === 10 ? 0 : partnerReward;
    
    const partnerRef = doc(db, "partners", referrerId);
    try {
      const currentBalance = partnerData.balance || 0;
      const currentTotalEarnings = partnerData.totalEarnings || 0;

      await updateDoc(partnerRef, {
        balance: currentBalance + actualReward,
        totalEarnings: currentTotalEarnings + actualReward
      });
      console.log("Partner balance updated");
    } catch (err) {
      console.error("Error updating partner balance:", err);
    }

    // 4. Track usage in 'referrals' collection
    if (newUserId) {
      try {
        await addDoc(collection(db, 'referrals'), {
          partnerUid: referrerId,
          newUserId: newUserId,
          playerEmail: formData.email,
          matchId: tournamentId,
          amount: actualReward,
          status: 'completed',
          createdAt: new Date().toISOString()
        });
        console.log("Referral usage tracked");

        // 5. Track in 'launch_refer' collection as requested
        await addDoc(collection(db, 'launch_refer'), {
          couponCode: code,
          partnerUid: referrerId,
          newUserId: newUserId,
          matchId: tournamentId,
          createdAt: new Date().toISOString()
        });
        console.log("Launch referral logged");
      } catch (err) {
        console.error("Error tracking referral usage:", err);
      }
    }

    return actualReward;
  }

