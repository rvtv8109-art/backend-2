                if (!latestRegistrationSnapshot.empty) {
                  const latestSquadNumber = latestRegistrationSnapshot.docs[0].data().squadNumber;
                  newSquadNumber = latestSquadNumber + 1;
                } else {
                  newSquadNumber = 1 + launchCupSnapshot.data().count;
                }
              } else {
                const launchApprovedRef = collection(db, 'launch_approved');
