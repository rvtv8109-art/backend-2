        const finalizeRegistration = async () => {
          try {
            const currentUserId = auth.currentUser?.uid;
            const collectionName = pendingData.tournamentId === 'grand-tournament' ? 'registrations' : `registrations_${pendingData.tournamentId.replace(/-/g, '_')}`;

            // Get current count to determine squad number
            let newSquadNumber = 1;

            if (pendingData.tournamentId === 'launch-cup') {
              const launchCupRef = collection(db, 'registrations_launch_cup');
              const launchCupSnapshot = await getCountFromServer(launchCupRef);
              
